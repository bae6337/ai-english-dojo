# ============================================================
# Streamlit Cloud Secrets template
# 사용법:
#   1) 이 파일을 그대로 GitHub 에 커밋해도 안전 (실제 키는 없음).
#   2) 로컬 테스트 시:
#        cp secrets.toml.example secrets.toml
#        secrets.toml 의 값들을 채운다 (커밋 금지).
#   3) Streamlit Cloud 에 배포한 후:
#        대시보드 → App settings → Secrets 에 아래 키들을 붙여 넣는다.
# ============================================================

# 필수 (OpenAI Realtime API 호출용)
OPENAI_API_KEY = "sk-..."

# 필수 (앱 접속 비밀번호)
APP_PASSWORD = "your-password-here"

# 선택 (모델 고정. 기본은 'gpt-realtime' 부터 자동 폴백)
# OPENAI_REALTIME_MODEL = "gpt-realtime"

# 선택 (음성 변경. 기본은 'alloy')
# OPENAI_REALTIME_VOICE = "alloy"
